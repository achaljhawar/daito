# India Screener MCP Server Environment Variables
# Copy this file to .env and fill in your credentials

# screener.in (Required for the query_india_screener tool)
# Ad-hoc queries on screener.in require a logged-in account.
# Free account at https://www.screener.in/register/
SCREENER_IN_EMAIL=your_screener_in_email_here
SCREENER_IN_PASSWORD=your_screener_in_password_here

# The get_india_fund_screener tool needs no credentials.
